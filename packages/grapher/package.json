{
  "name": "@metta-ts/grapher",
  "version": "1.1.4",
  "author": "MesTTo",
  "license": "MIT",
  "description": "MeTTaGrapher: a pure-SVG visual node-graph editor for MeTTa. Build a program as connected nodes, evaluate any subtree on the engine, and see the result. A node graph is a MeTTa atom.",
  "keywords": [
    "metta",
    "hyperon",
    "visual",
    "editor",
    "graph",
    "svg",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --platform browser"
  },
  "dependencies": {
    "@metta-ts/hyperon": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MesTTo/MeTTa-TS.git",
    "directory": "packages/grapher"
  },
  "homepage": "https://github.com/MesTTo/MeTTa-TS#readme",
  "bugs": {
    "url": "https://github.com/MesTTo/MeTTa-TS/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
